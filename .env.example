# ============================================================
# HouseMatch.nz — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_URL=https://yourdomain.com

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Session ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your-super-secret-session-key-at-least-32-chars

# ── Auth ─────────────────────────────────────────────────────
# Token for creating the first admin account via POST /api/admin/setup
ADMIN_SETUP_TOKEN=your-admin-setup-token
# Set to 'true' to skip email verification (dev only — never in production)
SKIP_EMAIL_VERIFICATION=false

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Anthropic (Claude) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Gmail (for transactional email) ──────────────────────────
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# ── Google Cloud Storage ─────────────────────────────────────
# Either set GOOGLE_APPLICATION_CREDENTIALS to a path, or paste the JSON here:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GCS_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
PUBLIC_OBJECT_SEARCH_PATHS=/your-bucket/public
PRIVATE_OBJECT_DIR=/your-bucket/private

# ── Sentry (error tracking) ───────────────────────────────────
SENTRY_DSN=https://xxx@sentry.io/yyy
SENTRY_CLIENT_SECRET=your-sentry-webhook-secret

# ── LINZ API ─────────────────────────────────────────────────
LINZ_API_KEY=your-linz-api-key

# ── TradeMe API ──────────────────────────────────────────────
TRADEME_CONSUMER_KEY=your-trademe-consumer-key
TRADEME_CONSUMER_SECRET=your-trademe-consumer-secret
TRADEME_OAUTH_TOKEN=your-oauth-token
TRADEME_OAUTH_TOKEN_SECRET=your-oauth-token-secret
# Set to 'true' to use TradeMe sandbox environment
TRADEME_SANDBOX=true

# ── Facebook Conversion API ───────────────────────────────────
FACEBOOK_PIXEL_ID=your-pixel-id
FACEBOOK_ACCESS_TOKEN=your-capi-access-token

# ── Redis (optional — for AI response caching) ───────────────
REDIS_URL=redis://localhost:6379

# ── Open2View API ────────────────────────────────────────────
OPEN2VIEW_API_KEY=your-open2view-api-key

# ── Preferred Client Subscription (Stripe Price ID) ──────────
PREFERRED_CLIENT_MONTHLY_PRICE_ID=price_...
PREFERRED_CLIENT_ANNUAL_PRICE_ID=price_...
